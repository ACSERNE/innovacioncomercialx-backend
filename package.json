    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.6.1",
    "mongoose": "^8.15.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.1",
    "readline-sync": "^1.4.10",
    "sequelize": "^6.37.7",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^22.3.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.2"
