{
  "name": "innovacioncomercialx-backend",
  "version": "1.0.0",
  "description": "Backend del proyecto innovacioncomercialx",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "undo:migrate": "sequelize-cli db:migrate:undo:all",
    "undo:seed": "sequelize-cli db:seed:undo:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.821.0",
